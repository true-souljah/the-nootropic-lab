{
  "name": "nootropics-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:us": "npm run dev --workspace=apps/us",
    "dev:eu": "npm run dev --workspace=apps/eu",
    "dev:ca": "npm run dev --workspace=apps/ca",
    "dev:au": "npm run dev --workspace=apps/au",
    "dev:jp": "npm run dev --workspace=apps/jp",
    "dev:latam": "npm run dev --workspace=apps/latam",
    "dev:gcc": "npm run dev --workspace=apps/gcc",
    "dev:sea": "npm run dev --workspace=apps/sea",
    "build:us": "npm run build --workspace=apps/us",
    "build:eu": "npm run build --workspace=apps/eu",
    "build:ca": "npm run build --workspace=apps/ca",
    "build:au": "npm run build --workspace=apps/au",
    "build:jp": "npm run build --workspace=apps/jp",
    "build:latam": "npm run build --workspace=apps/latam",
    "build:gcc": "npm run build --workspace=apps/gcc",
    "build:sea": "npm run build --workspace=apps/sea",
    "build": "npm run build:us && npm run build:eu && npm run build:ca && npm run build:au && npm run build:jp && npm run build:latam && npm run build:gcc && npm run build:sea",
    "validate-data": "npx --yes tsx scripts/validate-data.ts",
    "check": "npm run validate-data",
    "test": "npm test --workspace=packages/ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "serve": "^14.2.6",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
